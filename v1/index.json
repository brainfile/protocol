{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Brainfile v1 Schema Directory",
  "description": "Official schemas hosted at brainfile.md/v1/",
  "version": "1.1.0",
  "baseUrl": "https://brainfile.md/v1",
  "schemas": {
    "base": {
      "id": "base",
      "title": "Base Schema",
      "description": "Shared fields across all brainfiles",
      "url": "https://brainfile.md/v1/base.json",
      "status": "stable",
      "extends": null,
      "requiredFields": ["title"],
      "optionalFields": ["type", "schema", "protocolVersion", "agent", "rules"]
    },
    "board": {
      "id": "board",
      "title": "Board Schema",
      "description": "Kanban-style task boards. In v2, config-only (columns, rules, metadata). Tasks are standalone files validated against task.json.",
      "url": "https://brainfile.md/v1/board.json",
      "status": "stable",
      "extends": "base",
      "renderer": "kanban",
      "requiredFields": ["columns"],
      "structuralPattern": "columns[]",
      "examples": [
        "https://brainfile.md/example/board.md"
      ]
    },
    "task": {
      "id": "task",
      "title": "Task Schema",
      "description": "Standalone task document for per-task file architecture. Each task is an individual .md file with YAML frontmatter (metadata) and optional markdown body (narrative, log).",
      "url": "https://brainfile.md/v1/task.json",
      "status": "stable",
      "extends": null,
      "requiredFields": ["id", "title"],
      "conditionallyRequired": ["column (required for active tasks, omitted for completed tasks)"],
      "optionalFields": ["position", "description", "assignee", "tags", "priority", "effort", "blockedBy", "dueDate", "createdAt", "updatedAt", "completedAt", "relatedFiles", "subtasks", "template", "contract"],
      "filePattern": ".brainfile/tasks/*.md",
      "completedFilePattern": ".brainfile/logs/*.md"
    },
    "contract": {
      "id": "contract",
      "title": "Contract Schema",
      "description": "Task contract object for PM-to-agent workflows (Task.contract). In v2, context is deprecated in favor of task.description and task.relatedFiles.",
      "url": "https://brainfile.md/v1/contract.json",
      "status": "stable",
      "extends": null,
      "requiredFields": ["status"],
      "optionalFields": ["version", "deliverables", "validation", "constraints", "outOfScope", "feedback", "metrics", "context"]
    }
  },
  "links": {
    "documentation": "https://brainfile.md/protocol/",
    "repository": "https://github.com/brainfile/protocol",
    "npm": "https://www.npmjs.com/package/@brainfile/core",
    "vscode": "https://marketplace.visualstudio.com/items?itemName=brainfile.brainfile"
  }
}
